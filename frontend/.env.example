# ─────────────────────────────────────────────────────────────────────────────
# Frontend — Environment Variables
# Copy this file to .env and adjust values if needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Local Dev (npm run dev) ────────────────────────────────────────────────────
# Vite reads this and proxies /request /burst /reset /health to this URL.
# Change only if your rate-limiter runs on a different port locally.
RATE_LIMITER_DEV_URL=

# Optional: override the Vite dev server port (default: 3000)
# FRONTEND_DEV_PORT=3000

# ── Docker / Cloud Deployment ─────────────────────────────────────────────────
# When deployed, nginx proxies API calls using RATE_LIMITER_URL (not the var above).
# Set RATE_LIMITER_URL as an env var in your deployment platform — it is substituted
# into nginx.conf at container startup, so no rebuild is needed to change it.
#
# Docker Compose        → http://rate-limiter:4000          (set in Dockerfile default)
# Railway internal net  → http://<service-name>.railway.internal:<port>
# AWS ECS               → http://<service-discovery-name>:4000
# Azure Container Apps  → https://<app-name>.<env>.<region>.azurecontainerapps.io
# Kubernetes            → http://<svc>.<namespace>.svc.cluster.local:4000
RATE_LIMITER_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Root .env — used by Docker Compose (docker-compose.yml reads this automatically)
# Copy this file to .env before running `docker compose up`
# ─────────────────────────────────────────────────────────────────────────────

# ── Rate Limiter ──────────────────────────────────────────────────────────────
RATE_LIMITER_PORT=

# ── Server-1 ──────────────────────────────────────────────────────────────────
SERVER_1_PORT=
SERVER_1_NAME=

# ── Server-2 ──────────────────────────────────────────────────────────────────
SERVER_2_PORT=
SERVER_2_NAME=

# ── Frontend (nginx) ──────────────────────────────────────────────────────────
FRONTEND_PORT=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis runs as a Docker container — host/port are internal Docker network names.
# Do NOT change REDIS_HOST — it must match the service name in docker-compose.yml
REDIS_HOST=
REDIS_PORT=6
